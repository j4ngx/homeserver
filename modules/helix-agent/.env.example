# =============================================================================
# Helix Agent — Secrets
# =============================================================================
# Non-secret settings live in config.yml (version-controlled).
# This file holds secrets only — never commit .env to git.
#
# How to fill in these values:
#   Telegram bot token  → chat with @BotFather on Telegram → /newbot
#   Telegram user ID    → chat with @userinfobot on Telegram → forward any message
#   Groq API key        → https://console.groq.com/keys
#   OpenRouter API key  → https://openrouter.ai/settings/keys  (optional fallback)
# =============================================================================

# @required @secret @desc Token del bot de Telegram — @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# @required @desc Tu ID numérico de Telegram (ej: 123456789). Varios IDs separados por coma.
# Usa @userinfobot para obtener el tuyo.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# @required @secret @desc API Key de Groq (proveedor LLM principal)
GROQ_API_KEY=your_groq_api_key_here

# API Key de OpenRouter (LLM de fallback — opcional, déjalo vacío para desactivar)
OPENROUTER_API_KEY=
