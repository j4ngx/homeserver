# =============================================================================
# Pi-hole configuration
# =============================================================================
# Copy this file to .env and edit the values below.

# Timezone (IANA format)
TZ=Europe/Madrid

# Pi-hole admin web interface password
# CHANGE THIS before starting the module!
# @required
# @secret
# @desc Pi-hole admin web UI password
PIHOLE_PASSWORD=changeme

# Upstream DNS servers (semicolon-separated)
# Examples: 1.1.1.1;1.0.0.1  or  8.8.8.8;8.8.4.4
UPSTREAM_DNS=1.1.1.1;8.8.8.8

# The static IP of this server on the LAN.
# Pi-hole uses this to respond with the correct block page.
# @required
# @desc Static LAN IP of this server (e.g. 192.168.1.50)
SERVER_IP=192.168.1.224
