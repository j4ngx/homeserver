# =============================================================================
# Watchtower — Environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# Timezone
TZ=Europe/Madrid

# ---------------------------------------------------------------------------
# Schedule (cron expression — seconds field included)
# Default: every Sunday at 03:00 AM
# Format:  seconds minutes hours day month weekday
# ---------------------------------------------------------------------------
WATCHTOWER_SCHEDULE=0 0 3 * * 0

# ---------------------------------------------------------------------------
# Telegram notifications via Shoutrrr
# Format: telegram://<BOT_TOKEN>@telegram?channels=<CHAT_ID>
# Docs:   https://containrrr.dev/shoutrrr/services/telegram/
# Leave empty to disable notifications.
# ---------------------------------------------------------------------------
WATCHTOWER_NOTIFICATION_URL=

# Notification verbosity: debug | info | warn | error
WATCHTOWER_NOTIFICATIONS_LEVEL=info

# Watchtower log level: trace | debug | info | warn | error | fatal | panic
WATCHTOWER_LOG_LEVEL=info
