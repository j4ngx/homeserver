# =============================================================================
# MagicMirror² configuration
# =============================================================================

# Timezone (IANA format)
TZ=Europe/Madrid

# @required
# @secret
# @desc Clave de API de OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_api_key_here

# @required
# @desc URL pública ICS de tu calendario (iCloud: Calendario → compartir → Copiar enlace; Google: Configuración → Dirección ICAL)
ICAL_URL=your_ical_url_here
