# =============================================================================
# Backend Template — Environment variables
# =============================================================================
# Copy to .env and edit as needed.

# Application
APP_NAME=backend-template
APP_ENV=production
APP_PORT=8000
LOG_LEVEL=info

# Database (SQLite by default; change to PostgreSQL for production)
# SQLite:     sqlite:///./data/app.db
# PostgreSQL: postgresql://user:password@db:5432/mydb
DATABASE_URL=sqlite:///./data/app.db
