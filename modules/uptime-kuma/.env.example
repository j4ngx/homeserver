# =============================================================================
# Uptime Kuma — Environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# Timezone (used for alert timestamps and UI display)
TZ=Europe/Madrid

# ---------------------------------------------------------------------------
# Telegram alerts
# See: https://uptime.kuma.pet/docs/notifications/telegram
# ---------------------------------------------------------------------------

# Bot token from @BotFather  (e.g. 1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
# @required
# @secret
# @desc Telegram bot token from @BotFather (leave blank to skip)
TELEGRAM_BOT_TOKEN=REPLACE_WITH_YOUR_BOT_TOKEN

# Chat ID of the conversation to send alerts to
# Get it via: curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
# @required
# @desc Telegram chat ID to receive alerts (leave blank to skip)
TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_CHAT_ID
