# =============================================================================
# GitHub Actions Runner configuration
# =============================================================================
# Copy to .env and fill in the values below.

# ── GitHub repository or organization ────────────────────────────────────
# For repo-level runner:
# @required
# @desc GitHub username or organisation (e.g. j4ngx)
GITHUB_OWNER=your-github-username
# @required
# @desc Repository name (e.g. homeserver)
GITHUB_REPO=your-repo-name

# For org-level runner, set RUNNER_SCOPE=org and use GITHUB_OWNER as the org.

# ── Runner registration token ───────────────────────────────────────────
# Generate at:
#   Repo:  https://github.com/<owner>/<repo>/settings/actions/runners/new
#   Org:   https://github.com/organizations/<org>/settings/actions/runners/new
#
# Or use a fine-grained Personal Access Token (PAT) with:
#   - Repository access → selected repos
#   - Permissions → Administration (read/write)
#   - Permissions → Actions (read)
# @required
# @secret
# @desc GitHub PAT or runner registration token
RUNNER_TOKEN=your_runner_token_here

# ── Runner configuration ────────────────────────────────────────────────
RUNNER_NAME=endurance-runner
RUNNER_LABELS=self-hosted,linux,endurance
RUNNER_GROUP=default

# Scope: "repo" (single repository) or "org" (organization)
RUNNER_SCOPE=repo

# Set to true to create ephemeral runners (single job, then re-register)
EPHEMERAL=false

# Set to true to prevent the runner from auto-updating
DISABLE_AUTO_UPDATE=false
